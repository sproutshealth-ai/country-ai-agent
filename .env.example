# Choose ONE of these configurations:

# ===== OPTION 1: Azure OpenAI (Priority if all variables set) =====
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ===== OPTION 2: Standard OpenAI API =====
# OPENAI_API_KEY=your-openai-api-key-here
# MODEL_NAME=gpt-4o-mini

# ===== OPTION 3: Anthropic Claude =====
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# MODEL_NAME=claude-3-5-sonnet-20241022

# Model selection (only used for non-Azure deployments)
# Options: gpt-4o-mini, gpt-4o, claude-3-5-sonnet-20241022
MODEL_NAME=gpt-4o-mini
